# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Azure AD / Microsoft 365
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# Dynamics 365 Sales
D365_SALES_ORG=your-org-name
D365_SALES_BASE_URL=https://your-org-name.crm.dynamics.com

# Dynamics 365 Finance & Operations
D365_FINANCE_ORG=your-finance-org
D365_FINANCE_BASE_URL=https://your-finance-org.operations.dynamics.com

# Monday.com
MONDAY_API_KEY=your-monday-api-key
MONDAY_PROJECT_BOARD_ID=board-id-here
MONDAY_SPRINT_BOARD_ID=sprint-board-id-here
MONDAY_RESOURCE_BOARD_ID=resource-board-id-here

# WorkBoard
WORKBOARD_API_KEY=your-workboard-api-key
WORKBOARD_BASE_URL=https://app.workboard.com/api/v1
